{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@icecode/core": ["../ts-core/src/index.ts"],
      "@icecode/core/*": ["../ts-core/src/*.ts"],
      "@/*": ["../ts-runtime/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
