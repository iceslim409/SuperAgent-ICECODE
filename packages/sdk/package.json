{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@icecode/sdk",
  "version": "2.0.0",
  "type": "module",
  "license": "ICECODE-NC-1.0",
  "scripts": {
    "build": "bun build src/index.ts src/client.ts src/server.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./v2": "./src/v2/index.ts",
    "./v2/client": "./src/v2/client.ts",
    "./v2/gen/client": "./src/v2/gen/client/index.ts",
    "./v2/server": "./src/v2/server.ts"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.3",
    "@types/bun": "^1.2.0"
  },
  "dependencies": {
    "cross-spawn": "^7.0.6"
  }
}
