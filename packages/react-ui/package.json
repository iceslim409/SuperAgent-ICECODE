{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@icecode/react-ui",
  "version": "2.0.0",
  "type": "module",
  "description": "ICECODE React UI — desktop frontend [experimental — not yet integrated with Python backend]",
  "scripts": {
    "build": "bun build src/app.tsx --outdir dist --target browser --loader '.css=text'",
    "dev": "vite",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@icecode/core": "workspace:*",
    "@icecode/sdk": "workspace:*",
    "@icecode/shared": "workspace:*",
    "@icecode/ts-runtime": "workspace:*",
    "@icecode/ui": "workspace:*",
    "@kobalte/core": "0.13.11",
    "@sentry/solid": "10.36.0",
    "@solid-primitives/event-bus": "1.1.2",
    "@solid-primitives/event-listener": "2.4.5",
    "@solid-primitives/i18n": "2.2.1",
    "@solid-primitives/media": "2.3.3",
    "@solid-primitives/resize-observer": "2.1.3",
    "@solid-primitives/storage": "4.3.3",
    "@solid-primitives/timer": "1.4.4",
    "@solidjs/meta": "0.29.4",
    "@solidjs/router": "0.15.4",
    "@tanstack/solid-query": "5.91.4",
    "@thisbeyond/solid-dnd": "0.7.5",
    "effect": "4.0.0-beta.59",
    "fuzzysort": "3.1.0",
    "luxon": "3.6.1",
    "remeda": "2.26.0",
    "solid-js": "1.9.10",
    "zod": "^3.24.0"
  },
  "status": "experimental",
  "license": "ICECODE-NC-1.0"
}
