{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "2.0.0",
  "name": "@icecode/core",
  "type": "module",
  "license": "ICECODE-NC-1.0",
  "private": false,
  "scripts": {
    "test": "bun test",
    "test:ci": "mkdir -p .artifacts/unit && bun test --timeout 30000 --reporter=junit --reporter-outfile=.artifacts/unit/junit.xml",
    "typecheck": "tsgo --noEmit",
    "build": "bun build src/filesystem.ts src/global.ts src/schema.ts src/npm.ts src/effect-zod.ts --outdir dist --target bun --external effect --external @effect/platform-node --external @effect/opentelemetry --external @opentelemetry/api --external @npmcli/arborist --external cross-spawn --external glob --external semver"
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "imports": {},
  "devDependencies": {
    "@tsconfig/bun": "^1.0.3",
    "@types/bun": "^1.2.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/npm-package-arg": "6.1.4",
    "@types/npmcli__arborist": "6.3.3",
    "@types/semver": "^7.5.8"
  },
  "dependencies": {
    "@effect/opentelemetry": "4.0.0-beta.57",
    "@effect/platform-node": "4.0.0-beta.57",
    "@npmcli/arborist": "9.4.0",
    "@npmcli/config": "10.8.1",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/context-async-hooks": "2.6.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "cross-spawn": "^7.0.6",
    "effect": "4.0.0-beta.59",
    "glob": "13.0.5",
    "mime-types": "3.0.2",
    "minimatch": "10.2.5",
    "npm-package-arg": "13.0.2",
    "semver": "^7.6.3",
    "xdg-basedir": "5.1.0",
    "zod": "^3.24.0"
  },
  "overrides": {
    "drizzle-orm": "catalog:"
  }
}
