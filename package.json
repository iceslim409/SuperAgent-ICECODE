{
  "name": "icecode",
  "version": "2.0.0",
  "private": true,
  "description": "ICECODE Super-Agent Network — unified AI platform combining Hermes, ClawX and OpenCode",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "start": "cd packages/server && python -m uvicorn icecode_server.main:app --host 0.0.0.0 --port 13210",
    "desktop": "pnpm --filter @icecode/desktop-app dev",
    "tui": "pnpm --filter @icecode/cli dev",
    "server": "pnpm --filter @icecode/server dev",
    "clean": "turbo run clean && find . -name 'node_modules' -type d -not -path '*/\\.git/*' | xargs rm -rf"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "eslint": "^9.18.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "license": "ICECODE-NC-1.0"
}
