# ICECODE Super-Agent Network — Environment Variables

# =============================================================
# === LOCAL INFERENCE (modele mari local, resurse minime)    ===
# =============================================================
# Hermes auto-detecteaza: Ollama, LM Studio, vLLM, llama.cpp
# Citeste context length REAL din GGUF metadata (nu default 2048)
# Comprima automat contextul la 50% threshold
# Timeout adaptat pentru prefill lent pe hardware modest

# Ollama (cel mai simplu: ollama serve + ollama pull qwen2.5:7b)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Modelul auxiliar MIC (pentru sumarizare context, titluri, clasificare)
# Economiseste VRAM: modelul principal nu face sumarizare singur
# Recomandat: qwen2.5:1.5b sau phi3.5:3.8b (foarte rapid, resurse minime)
LOCAL_AUX_MODEL=qwen2.5:1.5b
LOCAL_AUX_URL=http://localhost:11434

# LM Studio (alternativa cu UI, suporta GGUF cu quantizare)
# LMSTUDIO_URL=http://localhost:1234
# LMSTUDIO_MODEL=

# vLLM (pentru GPU dedicat, throughput mare)
# VLLM_URL=http://localhost:8000
# VLLM_MODEL=

# llama.cpp server
# LLAMACPP_URL=http://localhost:8080
# LLAMACPP_MODEL=

# Context compression threshold (0.50 = comprima la 50% din context window)
# Scade la 0.40 pentru modele cu context mic (2K-4K)
CONTEXT_COMPRESSION_THRESHOLD=0.50

# Timeout stream local (secunde) - modelele locale sunt lente la prefill
LOCAL_STREAM_TIMEOUT=1800

# Prioritizeaza modele locale cand sunt disponibile (false = cloud implicit)
PREFER_LOCAL_MODELS=false

